<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".fragments.AnswerDialogFragment">


    <ImageButton
        android:id="@+id/bt_clear"
        android:layout_width="121dp"
        android:layout_height="63dp"
        android:layout_marginStart="40dp"
        android:background="@android:color/transparent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline9"
        app:srcCompat="@android:drawable/ic_menu_revert" />

    <ImageButton
        android:id="@+id/bt_confirm"
        android:layout_width="130dp"
        android:layout_height="62dp"
        android:layout_marginEnd="24dp"
        android:background="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline9"
        app:srcCompat="@drawable/green_tick" />

    <TextView
            android:id="@+id/labAge"
            android:layout_width="118dp"
            android:layout_height="20dp"
            android:layout_marginStart="40dp"
            android:layout_marginTop="40dp"
            android:text="@string/age"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/labName" />

    <TextView
            android:id="@+id/labName"
            android:layout_width="119dp"
            android:layout_height="21dp"
            android:layout_marginStart="40dp"
            android:layout_marginTop="40dp"
            android:text="@string/name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <EditText
            android:id="@+id/txtAge"
            android:layout_width="135dp"
            android:layout_height="47dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="16dp"
            android:ems="10"
            android:inputType="none|number"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txtName" />

    <EditText
            android:id="@+id/txtName"
            android:layout_width="135dp"
            android:layout_height="46dp"
            android:layout_marginTop="16dp"
            android:ems="10"
            android:inputType="textPersonName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.862"
            app:layout_constraintStart_toEndOf="@+id/labName"
            app:layout_constraintTop_toTopOf="parent" />

    <RadioGroup
            android:id="@+id/radioGroupGender"
            android:layout_width="135dp"
            android:layout_height="42dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="12dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txtAge">

        <RadioButton
                android:id="@+id/rb_male"
                android:layout_width="65dp"
                android:layout_height="45dp"
                android:text="@string/tid_rb_male_text" />

        <RadioButton
                android:id="@+id/rb_female"
                android:layout_width="69dp"
                android:layout_height="match_parent"
                android:text="@string/tid_rb_female_text" />
    </RadioGroup>

    <Button
        android:id="@+id/bt_cancel"
        android:layout_width="371dp"
        android:layout_height="55dp"
        android:layout_marginTop="84dp"
        android:text="Cancel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline9" />

    <Spinner
            android:id="@+id/spCondition"
            android:layout_width="319dp"
            android:layout_height="27dp"
            android:layout_marginTop="68dp"
            android:layout_marginEnd="12dp"
            android:textAlignment="textEnd"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/radioGroupGender" />

    <TextView
        android:id="@+id/labInteractive"
        android:layout_width="120dp"
        android:layout_height="24dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="36dp"
        android:text="@string/interactivity"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/labWhiteNoise" />

    <Switch
        android:id="@+id/swInteractive"
        android:layout_width="137dp"
        android:layout_height="27dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/swWhiteNoise" />

    <TextView
        android:id="@+id/labWhiteNoise"
        android:layout_width="176dp"
        android:layout_height="24dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="32dp"
        android:text="@string/whitenoise"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spCondition" />

    <Switch
        android:id="@+id/swWhiteNoise"
        android:layout_width="69dp"
        android:layout_height="35dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spCondition" />


    <TextView
            android:id="@+id/labCondition"
            android:layout_width="191dp"
            android:layout_height="30dp"
            android:layout_marginStart="40dp"
            android:layout_marginTop="36dp"
            android:text="@string/condition"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/labGender" />

    <TextView
            android:id="@+id/labGender"
            android:layout_width="117dp"
            android:layout_height="24dp"
            android:layout_marginStart="40dp"
            android:layout_marginTop="40dp"
            android:text="@string/gender"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/labAge" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline9"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="435dp" />

</androidx.constraintlayout.widget.ConstraintLayout>